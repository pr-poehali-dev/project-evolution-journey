{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET content",
      "method": "GET",
      "path": "/?action=content",
      "expectedStatus": 200,
      "expectedBody": {"content": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Регистрация — дубль",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "test_clodev@example.com", "password": "securepass123", "plan": "free"},
      "expectedStatus": 409,
      "expectedBody": {"error": "Пользователь с таким email уже существует"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Вход — неверный пароль",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_clodev@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Вход — верные данные",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_clodev@example.com", "password": "securepass123"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Биллинг — нет доступа",
      "method": "POST",
      "path": "/",
      "body": {"action": "billing", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Нет доступа"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET projects user_id=1",
      "method": "GET",
      "path": "/?action=projects&user_id=1",
      "expectedStatus": 200,
      "expectedBody": {"projects": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "git_deploy — нет repo_url",
      "method": "POST",
      "path": "/",
      "body": {"action": "git_deploy", "project_id": 1, "user_id": 1},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "git_deploy — проект не найден",
      "method": "POST",
      "path": "/",
      "body": {"action": "git_deploy", "project_id": 999999, "user_id": 999999, "repo_url": "https://github.com/vitejs/vite"},
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "git_detect — нет repo_url",
      "method": "GET",
      "path": "/?action=git_detect",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}